{
  "mcpServers": {
    "railway": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"]
    },
    "redis": {
      "command": "npx",
      "args": ["-y", "@gongrzhe/server-redis-mcp", "${REDIS_URL}"]
    },
    "helius": {
      "command": "npx",
      "args": ["-y", "helius-mcp@latest"],
      "env": {
        "HELIUS_API_KEY": "${HELIUS_API_KEY}"
      }
    },
    "nansen": {
      "type": "http",
      "url": "https://mcp.nansen.ai/ra/mcp",
      "headers": {
        "NANSEN-API-KEY": "${NANSEN_API_KEY}"
      }
    },
    "vybe": {
      "type": "http",
      "url": "https://api.vybenetwork.xyz/mcp",
      "headers": {
        "X-API-KEY": "${VYBE_API_KEY}"
      }
    },
    "coingecko": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.api.coingecko.com/mcp"]
    },
    "dexpaprika": {
      "type": "http",
      "url": "https://mcp.dexpaprika.com/streamable-http"
    },
    "defillama": {
      "type": "http",
      "url": "https://mcp.defillama.com/mcp"
    },
    "birdeye": {
      "type": "http",
      "url": "https://mcp.birdeye.so/mcp",
      "headers": {
        "X-API-KEY": "${BIRDEYE_API_KEY}"
      }
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "shadcn": {
      "command": "npx",
      "args": ["-y", "shadcn@latest", "mcp"]
    },
    "socket": {
      "type": "http",
      "url": "https://mcp.socket.dev/"
    }
  }
}
