# === BLOCKCHAIN / HELIUS ===
HELIUS_RPC_URL=                    # Standard RPC — getBalance, getAccountInfo, etc. (https://mainnet.helius-rpc.com/?api-key=...)
HELIUS_STAKED_URL=                 # Staked connection — fastest tx landing (https://staked-mainnet.helius-rpc.com/?api-key=...)
HELIUS_PARSE_TX_URL=              # Parse specific transactions (https://api.helius.xyz/v0/transactions?api-key=...)
HELIUS_PARSE_HISTORY_URL=         # Parse wallet tx history — {address} placeholder (https://api.helius.xyz/v0/addresses/{address}/transactions?api-key=...)
HELIUS_GATEKEEPER_URL=            # Fallback RPC if primary fails (https://rpc-gatekeeper-mainnet.helius-rpc.com/?api-key=...)
JITO_ENDPOINT=https://mainnet.block-engine.jito.wtf/api/v1/bundles
JUPITER_API_KEY=                   # Jupiter API key -- free at https://portal.jup.ag

# === TRADING WALLETS ===
TRADING_WALLET_PRIVATE_KEY=        # Base58 private key — NEVER commit, env only
TRADING_WALLET_ADDRESS=            # Public key of trading wallet
HOLDING_WALLET_ADDRESS=            # Public key ONLY — no private key needed/allowed

# === TREASURY ===
TREASURY_TRIGGER_SOL=30.0          # Sweep when trading wallet exceeds this
TREASURY_TARGET_SOL=25.0           # Leave this much after sweep
TREASURY_MIN_TRANSFER_SOL=1.0      # Minimum single transfer amount

# === DATA APIS ===
VYBE_API_KEY=                      # vybenetwork.xyz (free tier)
NANSEN_API_KEY=                    # From nansen.ai Pro — $49/mo (smart money signals, wallet PnL, token screener)

# === GOVERNANCE ===
ANTHROPIC_API_KEY=                 # From console.anthropic.com — for governance agent
GOVERNANCE_MODEL=claude-sonnet-4-6 # Model to use for governance tasks

# === ALERTS ===
DISCORD_WEBHOOK_URL=               # Discord webhook for alerts + daily briefings
DISCORD_WEBHOOK_TREASURY=          # Separate channel for treasury sweep notifications

# === DISCORD NANSEN ALERTS ===
DISCORD_BOT_TOKEN=                 # From discord.com/developers/applications → Bot → Reset Token
DISCORD_NANSEN_CHANNEL_ID=         # Right-click channel in Discord -> Copy Channel ID (need Developer Mode on)
DISCORD_OWNER_ID=                  # Your Discord user ID for !zmn commands (right-click yourself -> Copy User ID)

# === INFRASTRUCTURE ===
REDIS_URL=                         # Railway Redis plugin
DATABASE_URL=sqlite:///toxibot.db
DATABASE_PATH=toxibot.db
DASHBOARD_SECRET=                  # JWT signing secret + login password (min 20 chars recommended)
DASHBOARD_ALLOWED_IPS=             # Optional comma-separated IP whitelist (leave blank to allow all)

# === RUNTIME ===
ENVIRONMENT=development            # 'development' or 'production'
TEST_MODE=true                     # true = detect signals, never execute trades
STARTING_CAPITAL_SOL=20
LOG_LEVEL=INFO
